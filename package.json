{
  "name": "proyecto-final",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "db:migrate": "pnpm --filter api prisma:migrate",
    "db:generate": "pnpm --filter api prisma:generate",
    "db:push": "pnpm --filter api prisma:push",
    "db:studio": "pnpm --filter api prisma:studio",
    "db:seed": "pnpm --filter api prisma:seed",
    "db:reset": "pnpm --filter api prisma:reset",
    "test": "pnpm --filter api test",
    "format:api": "pnpm --filter api format",
    "format:web": "pnpm --filter web format"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "prisma",
      "bcrypt",
      "esbuild"
    ]
  }
}
